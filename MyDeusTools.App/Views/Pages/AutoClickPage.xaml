<Page x:Class="MyDeusTools.App.Views.Pages.AutoClickPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MyDeusTools.App.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="AutoClicker Pro"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <Grid Margin="30,20,30,20" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AutoClicker Pro" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Navigation Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="BtnForm1" Content="Cấu hình cơ bản" Style="{StaticResource {x:Type ToggleButton}}" IsChecked="True" Margin="0,0,10,0" Padding="20,8"/>
            <RadioButton x:Name="BtnForm2" Content="Khoảng cách &amp; Lặp lại" Style="{StaticResource {x:Type ToggleButton}}" Margin="0,0,10,0" Padding="20,8"/>
            <RadioButton x:Name="BtnForm3" Content="Ghi tọa độ" Style="{StaticResource {x:Type ToggleButton}}" Padding="20,8"/>
        </StackPanel>

        <!-- Form 1: Cấu hình cơ bản -->
        <StackPanel Grid.Row="2">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnForm1}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Phím chuột" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding MouseButtons}" 
                              SelectedItem="{Binding SelectedMouseButton}" 
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </ui:Card>
            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Kiểu click" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding ClickTypes}" 
                              SelectedItem="{Binding SelectedClickType}" 
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </ui:Card>
            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Phím tắt" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding HotkeyDisplayText}" 
                                   VerticalAlignment="Center" 
                                   FontWeight="SemiBold" 
                                   FontSize="14"/>
                        <ui:Button Grid.Column="1" 
                                   Content="Đổi phím tắt" 
                                   Command="{Binding StartListeningCommand}"
                                   Appearance="Secondary"
                                   Padding="16,4"/>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Form 2: Thời gian & Lặp lại -->
        <StackPanel Grid.Row="2">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnForm2}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Thời gian nghỉ giữa các lần Click" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Giờ" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ui:NumberBox Grid.Column="1" Value="{Binding Hours}" Minimum="0" Maximum="23" Margin="0,0,20,0"/>
                        
                        <TextBlock Grid.Column="2" Text="Phút" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ui:NumberBox Grid.Column="3" Value="{Binding Minutes}" Minimum="0" Maximum="59" Margin="0,0,20,0"/>
                        
                        <TextBlock Grid.Column="4" Text="Giây" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ui:NumberBox Grid.Column="5" Value="{Binding Seconds}" Minimum="0" Maximum="59" Margin="0,0,20,0"/>
                        
                        <TextBlock Grid.Column="6" Text="Ms" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ui:NumberBox Grid.Column="7" Value="{Binding Milliseconds}" Minimum="10" Maximum="999"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Số lần lặp lại" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="Nhập 0 để lặp lại vô hạn" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                    <ui:NumberBox Value="{Binding RepeatCount}" Minimum="0" PlaceholderText="Ví dụ: 100"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Form 3: Ghi tọa độ -->
        <StackPanel Grid.Row="2">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnForm3}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <ui:Card Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Số điểm đã ghi" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding RecordedPointsCount}" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <ui:Button Grid.Column="1" 
                               Content="{Binding RecordButtonText}" 
                               Command="{Binding ToggleRecordCommand}"
                               Icon="{ui:SymbolIcon Record24}"
                               Margin="0,0,10,0"/>
                    <ui:Button Grid.Column="2" 
                               Content="Xóa" 
                               Command="{Binding ClearRecordingCommand}"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Delete24}"/>
                </Grid>
            </ui:Card>
        </StackPanel>

        <!-- Footer: Control -->
        <ui:Card Grid.Row="3" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,20,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Trạng thái" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <ui:Button Grid.Column="1" 
                           Content="{Binding ButtonText}" 
                           Command="{Binding ToggleClickCommand}"
                           Appearance="Primary"
                           FontSize="16"
                           Padding="30,10"/>
            </Grid>
        </ui:Card>

        <ui:InfoBar Grid.Row="4" Title="Mẹo" 
                    Message="Bạn có thể nhấn phím tắt bất cứ lúc nào để Bật/Tắt clicker." 
                    Severity="Informational" 
                    IsOpen="True" 
                    IsClosable="False"/>
    </Grid>
</Page>
