<Page x:Class="MyDeusTools.App.Views.Pages.ShutdownPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Schedule Shutdown"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="40">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="Hẹn giờ tắt máy" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <ui:Card Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="Thiết lập thời gian chờ:" Margin="0,0,0,15" FontWeight="SemiBold"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Giờ" Margin="0,0,0,5" FontSize="12"/>
                            <ui:NumberBox Value="{Binding Hours, Mode=TwoWay}" Minimum="0" Maximum="23" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Phút" Margin="0,0,0,5" FontSize="12"/>
                            <ui:NumberBox Value="{Binding Minutes, Mode=TwoWay}" Minimum="0" Maximum="59" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giây" Margin="0,0,0,5" FontSize="12"/>
                            <ui:NumberBox Value="{Binding Seconds, Mode=TwoWay}" Minimum="0" Maximum="59" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,20">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Trạng thái:" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ui:Button Grid.Column="1" 
                               Content="Hủy lệnh" 
                               Command="{Binding CancelCommand}"
                               Appearance="Secondary"
                               Margin="0,0,10,0"
                               Padding="15,8"/>

                    <ui:Button Grid.Column="2" 
                               Content="Bắt đầu" 
                               Command="{Binding ScheduleCommand}"
                               Appearance="Primary"
                               Padding="20,8"/>
                </Grid>
            </ui:Card>

            <ui:InfoBar Title="Lưu ý" 
                        Message="Lệnh này sẽ gọi shutdown.exe của hệ thống. Hãy đảm bảo bạn đã lưu lại các công việc đang làm."
                        Severity="Informational"
                        IsOpen="True" />
        </StackPanel>
    </Grid>
</Page>
