<Window x:Class="MyDeusTools.App.Views.Windows.RecordingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recording Overlay" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="#01000000" 
        Topmost="True" 
        ShowInTaskbar="False" 
        Cursor="Cross"
        MouseMove="Window_MouseMove"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">
    <Canvas>
        <Border x:Name="TooltipBorder" 
                Background="#CC000000" 
                CornerRadius="4" 
                Padding="8,4" 
                IsHitTestVisible="False">
            <TextBlock x:Name="CoordsText" 
                       Foreground="White" 
                       FontWeight="SemiBold" 
                       FontSize="14"/>
        </Border>
        
        <TextBlock x:Name="InstructionText" 
                   Text="Click để ghi tọa độ. Nhấn ESC để thoát." 
                   Foreground="White" 
                   Background="#AA000000" 
                   Padding="10" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   Canvas.Top="20" 
                   Canvas.Left="20" 
                   IsHitTestVisible="False"/>
    </Canvas>
</Window>
